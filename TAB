<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MÉTODO TAB - Gestão de Erros</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Syne:wght@700;800&display=swap" rel="stylesheet">
    <style>
        body { background-color: #f8f9fa; color: #212529; font-family: 'Inter', sans-serif; }
        .font-display { font-family: 'Syne', sans-serif; }
        .card { background: white; border: 1px solid #e9ecef; border-radius: 20px; padding: 20px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05); }
        .btn-primary { background-color: #212529; color: white; padding: 14px; border-radius: 14px; font-weight: 700; width: 100%; transition: all 0.2s; }
        .btn-primary:active { transform: scale(0.96); }
        input { background: white; border: 1px solid #e2e8f0; border-radius: 14px; padding: 12px 16px; width: 100%; outline: none; transition: border 0.2s; }
        input:focus { border-color: #3b82f6; }
    </style>
</head>
<body>
    <div id="root"></div>

    <script type="importmap">
    {
      "imports": {
        "react": "https://esm.sh/react@18.2.0",
        "react-dom/client": "https://esm.sh/react-dom@18.2.0/client",
        "lucide-react": "https://esm.sh/lucide-react@0.284.0",
        "framer-motion": "https://esm.sh/framer-motion@10.16.4",
        "@google/genai": "https://esm.sh/@google/genai@1.29.0"
      }
    }
    </script>

    <script type="module">
        import React, { useState, useEffect } from 'react';
        import { createRoot } from 'react-dom/client';
        import * as Lucide from 'lucide-react';
        import { motion, AnimatePresence } from 'framer-motion';
        import { GoogleGenAI, Type } from '@google/genai';

        function App() {
            const [apiKey, setApiKey] = useState(localStorage.getItem('metodo_tab_key') || '');
            const [activeTab, setActiveTab] = useState('registrar');
            const [errors, setErrors] = useState(() => JSON.parse(localStorage.getItem('tab_erros_v3') || '[]'));
            const [streak, setStreak] = useState(() => JSON.parse(localStorage.getItem('tab_streak_v3') || '{"count":0,"lastDate":""}'));
            const [loading, setLoading] = useState(false);

            // Salvar dados automaticamente
            useEffect(() => localStorage.setItem('tab_erros_v3', JSON.stringify(errors)), [errors]);
            useEffect(() => localStorage.setItem('tab_streak_v3', JSON.stringify(streak)), [streak]);
            useEffect(() => { if(apiKey) localStorage.setItem('metodo_tab_key', apiKey); }, [apiKey]);

            // --- TELA DE CONFIGURAÇÃO DA CHAVE ---
            if (!apiKey) {
                return (
                    <div className="min-h-screen flex items-center justify-center p-6 bg-gray-50">
                        <div className="card w-full max-w-sm space-y-6 text-center">
                            <Lucide.ShieldCheck size={48} className="mx-auto text-blue-500" />
                            <div>
                                <h1 className="font-display text-2xl font-extrabold">Configuração Segura</h1>
                                <p className="text-gray-500 text-sm mt-2">Cole sua chave do Google AI Studio abaixo. Ela ficará salva apenas no seu navegador.</p>
                            </div>
                            <input 
                                type="password" 
                                placeholder="Cole sua API Key aqui..." 
                                onKeyDown={(e) => { if(e.key === 'Enter') setApiKey(e.target.value); }}
                            />
                            <button onClick={(e) => setApiKey(e.previousSibling.value)} className="btn-primary">Ativar Aplicativo</button>
                            <a href="https://aistudio.google.com/app/apikey" target="_blank" className="text-xs text-blue-500 underline">Onde pegar minha chave?</a>
                        </div>
                    </div>
                );
            }

            // --- LÓGICA DE IA ---
            const generateAIQuestion = async (tema) => {
                setLoading(true);
                try {
                    const genAI = new GoogleGenAI({ apiKey });
                    const model = genAI.models.generateContent({
                        model: "gemini-1.5-flash",
                        contents: `Gere uma questão ENEM sobre: ${tema}. Retorne em JSON com campos: materia, enunciado, alternativas (array 5), gabarito (0-4), explicacao.`,
                        config: { responseMimeType: "application/json" }
                    });
                    const result = await model;
                    alert("Questão gerada! (Lógica de exibição simplificada nesta versão)");
                    console.log(JSON.parse(result.text));
                } catch (e) {
                    alert("Erro na IA. Verifique sua chave.");
                } finally { setLoading(false); }
            };

            const handleSave = (e) => {
                e.preventDefault();
                const f = e.target;
                setErrors([{ id: Date.now(), materia: f.materia.value, questao: f.questao.value, tab: f.tab.value }, ...errors]);
                const today = new Date().toISOString().split('T')[0];
                if(streak.lastDate !== today) setStreak({ count: streak.count + 1, lastDate: today });
                f.reset();
                setActiveTab('lista');
            };

            return (
                <div className="max-w-md mx-auto min-h-screen pb-24 px-4 pt-6">
                    <header className="flex justify-between items-center mb-8">
                        <h1 className="font-display text-2xl font-extrabold">MÉTODO <span className="text-blue-500">TAB</span></h1>
                        <div className="flex items-center gap-2 bg-amber-100 text-amber-600 px-3 py-1.5 rounded-full">
                            <Lucide.Flame size={16} fill="currentColor" />
                            <span className="font-bold">{streak.count}</span>
                        </div>
                    </header>

                    <main>
                        {activeTab === 'registrar' ? (
                            <form onSubmit={handleSave} className="space-y-6">
                                <h2 className="font-display text-lg font-bold">Registrar Erro</h2>
                                <input name="materia" placeholder="Matéria" required />
                                <input name="questao" placeholder="Questão (ex: Q01)" required />
                                <div className="grid grid-cols-3 gap-2">
                                    {['B', 'L', 'D'].map(t => (
                                        <label key={t} className="flex flex-col items-center p-3 border rounded-xl cursor-pointer has-[:checked]:bg-blue-50 has-[:checked]:border-blue-500">
                                            <input type="radio" name="tab" value={t} defaultChecked={t==='B'} className="hidden" />
                                            <span className="text-xs font-bold">{t === 'B' ? 'BANAL' : t === 'L' ? 'LACUNA' : 'DESCONH.'}</span>
                                        </label>
                                    ))}
                                </div>
                                <button type="submit" className="btn-primary">Salvar no Histórico</button>
                            </form>
                        ) : (
                            <div className="space-y-4">
                                <div className="flex justify-between items-center">
                                    <h2 className="font-display text-lg font-bold">Meus Erros</h2>
                                    <button onClick={() => { localStorage.removeItem('metodo_tab_key'); window.location.reload(); }} className="text-[10px] text-gray-400">Trocar Chave</button>
                                </div>
                                {errors.map(err => (
                                    <div key={err.id} className="card flex justify-between items-center">
                                        <div>
                                            <p className="font-bold text-sm">{err.materia} - {err.questao}</p>
                                            <span className="text-[10px] font-bold opacity-60">{err.tab}</span>
                                        </div>
                                        <button onClick={() => setErrors(errors.filter(e => e.id !== err.id))} className="text-red-400"><Lucide.Trash2 size={18}/></button>
                                    </div>
                                ))}
                            </div>
                        )}
                    </main>

                    <nav className="fixed bottom-0 left-0 right-0 bg-white border-t p-3 flex justify-around">
                        <button onClick={() => setActiveTab('registrar')} className={activeTab === 'registrar' ? 'text-blue-500' : 'text-gray-400'}><Lucide.Plus /></button>
                        <button onClick={() => setActiveTab('lista')} className={activeTab === 'lista' ? 'text-blue-500' : 'text-gray-400'}><Lucide.ListTodo /></button>
                    </nav>
                </div>
            );
        }

        createRoot(document.getElementById('root')).render(<App />);
    </script>
</body>
</html>
